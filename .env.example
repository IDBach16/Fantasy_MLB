# ============================================================
#  Fantasy MLB — SECRETS TEMPLATE
#  COPY this file to ".env" (same folder) and fill in the values.
#  The real .env is gitignored and is NEVER read into chat, the UI, or logs.
#  Ian fills this in directly — do not paste secrets into chat.
# ============================================================

# --- Claude API (PROVIDED BY IAN LATER — leave blank until the agent layer is built) ---
ANTHROPIC_API_KEY=

# --- Dashboard access gate (REQUIRED — the app is exposed publicly) ---
# dashboard.py refuses to serve pages until this password is entered.
APP_PASSWORD=
# Deployed dashboard URL — linked at the top of every emailed report.
DASHBOARD_URL=https://idbach16-fantasy-mlb.streamlit.app

# --- Every-3-days noon email + alerts (SMTP) ---
EMAIL_TO=idbach16@gmail.com
# GM "Front Office Report" copy — sent every OTHER report (~6 days), addressed to Mr. Corey Arnold
GM_EMAIL_TO=heyarnold386@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
# Gmail APP PASSWORD (not your normal login) — create at myaccount.google.com/apppasswords
# (requires 2-Step Verification). Spaces in the pasted code are OK; they're stripped.
SMTP_PASS=

# --- Per-league credentials (we add these one league at a time) ---
# Names are referenced from leagues/<slug>.yaml by KEY only (never the value).
# Uncomment / add the ones each league needs:
#
# ESPN private league (browser cookies — these exact names are what the code reads):
#   ESPN_S2=
#   ESPN_SWID=
# Yahoo (registered OAuth app):
#   YAHOO_CLIENT_ID=
#   YAHOO_CLIENT_SECRET=
# Fantrax (session cookie):
#   FANTRAX_COOKIE_LEAGUE1=
# Ottoneu (FanGraphs ACCOUNT login — one login covers ALL your Ottoneu leagues):
#   OTTONEU_USERNAME=
#   OTTONEU_PASSWORD=
#   (the app caches a session cookie after first login, so your password is only
#    sent again when the session expires — kept in secrets/ottoneu_session.json, gitignored)
